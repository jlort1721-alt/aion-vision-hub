# =============================================================================
# AION QA / E2E Test Environment
# -----------------------------------------------------------------------------
# Copia este archivo a /opt/aion/.env.qa en el VPS:
#   sudo cp .env.qa.example /opt/aion/.env.qa
#   sudo chown aion:aion    /opt/aion/.env.qa
#   sudo chmod 600          /opt/aion/.env.qa
#
# Los UUIDs aqui son LOS MISMOS que crea db/seeds/seed-qa-tenant.sql.
# Si corres el seed, no necesitas editar nada.
# Si tu DB ya tiene otros UUIDs, edita los valores manualmente.
# =============================================================================

# ---- Playwright base ---------------------------------------------------------
AION_BASE_URL=https://aionseg.co
AION_QA_RUN_ID=

# ---- Credenciales del bot QA (creadas por el seed) ---------------------------
AION_QA_EMAIL=qa-bot@aionseg.co
AION_QA_PASS=QA-bot-2026!
# IMPORTANTE: rota esta contraseña en produccion. El seed la deja por defecto
# para arranque rapido; cambiala desde la UI de admin antes del primer deploy.

# ---- UUIDs fijos del tenant QA (NO CAMBIAR sin actualizar el seed) ----------
AION_QA_TENANT_ID=11111111-1111-1111-1111-111111111111
AION_QA_SITE_ID=22222222-2222-2222-2222-222222222222
AION_QA_RESIDENT_ID=77777777-7777-7777-7777-777777777777
AION_QA_GUARD_ID=88888888-8888-8888-8888-888888888888
AION_QA_CONTROLLER_ID=99999999-9999-9999-9999-999999999999
AION_QA_ROUTE_ID=aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa
AION_QA_CHECKPOINT_1=bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb
AION_QA_CHECKPOINT_2=cccccccc-cccc-cccc-cccc-cccccccccccc
AION_QA_CHECKPOINT_3=dddddddd-dddd-dddd-dddd-dddddddddddd

# ---- Database / migrations (solo para migrate.sh y seed-qa.sh) --------------
DATABASE_URL=postgres://aion:CHANGEME@127.0.0.1:5432/aion
MIGRATIONS_DIR=/opt/aion/db/migrations
LOG_DIR=/var/log/aion
SNAPSHOT_DIR=/opt/aion/snapshots
