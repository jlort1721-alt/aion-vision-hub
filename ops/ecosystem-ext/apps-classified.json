{
  "_already_managed_by_v1_skip_these": ["aionseg-api"],

  "stateful_blue_green": {
    "apps": [
      {
        "name": "n8n-automations",
        "cwd": "/var/www/aionseg",
        "script": "/usr/bin/n8n",
        "base_port": 5678,
        "exec_mode": "fork",
        "instances": 1,
        "max_memory_restart": "1G",
        "kill_timeout": 30000,
        "health_endpoint": "/healthz",
        "env": {
          "N8N_PORT": "5678",
          "GENERIC_TIMEZONE": "America/Bogota"
        },
        "drain_strategy": "wait_for_inflight",
        "_notes": "Workflows activos en memoria, 325MB. Necesita drain antes de stop."
      }
    ]
  },

