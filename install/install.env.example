# =============================================================================
# AION Platform — install.env
# -----------------------------------------------------------------------------
# Copy to install.env (same dir as install.sh) and fill in real values.
# Used by `sudo ./install.sh --auto` for non-interactive installation.
# =============================================================================

# ---- AION user / dirs (defaults are usually fine) ---------------------------
AION_USER=aion
AION_ROOT=/opt/aion
LOG_DIR=/var/log/aion

# ---- Database (REQUIRED for migrate-rls + seed-qa + observability) ----------
# Format: postgres://USER:PASS@HOST:PORT/DB
# If you run Postgres locally as the aion user via peer auth, you can use:
#   postgres://aion@127.0.0.1:5432/aion
# Otherwise provide explicit password.
DATABASE_URL=postgres://aion:CHANGEME@127.0.0.1:5432/aion

# ---- Domain / TLS -----------------------------------------------------------
AION_DOMAIN=aionseg.co
AION_DOMAIN_WWW=www.aionseg.co
TLS_EMAIL=admin@aionseg.co     # for Let's Encrypt registration

# ---- Observability secrets (will be filled with random if blank) ------------
# Slack webhook for alerts (REQUIRED for production alerts)
SLACK_WEBHOOK_URL=

# Email via SendGrid (optional)
SENDGRID_API_KEY=

# QA bot bearer for blackbox-authed probes (generated after seed-qa phase)
QA_BOT_BEARER=

# Vision Hub auth token (only if your /api/vision-hub/health requires it)
VISION_HUB_TOKEN=

# Twilio (only if you want WhatsApp on-call alerts)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_US_NUMBER=

# ---- E2E QA credentials -----------------------------------------------------
# These are auto-set by the seed-qa phase (UUID 4444... user)
# Override here only if you are NOT running seed-qa
AION_QA_EMAIL=qa-bot@aionseg.co
AION_QA_PASS=QA-bot-2026!

# ---- Behavior flags ---------------------------------------------------------
# Skip TLS provisioning during install (run certbot manually later)
SKIP_TLS=0

# Skip starting PM2 apps (no codebase deployed yet)
SKIP_PM2_START=1

# Auto-confirm potentially-destructive actions (DB seed, etc.)
AUTO_CONFIRM=1
