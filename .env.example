# ═══════════════════════════════════════════════════════════
# AION Vision Hub — Frontend Environment Variables
# Copy to .env.local and fill in actual values
# ═══════════════════════════════════════════════════════════

# ── Backend API URL (Required — Fastify server) ──
# Required for all API calls to the backend
VITE_API_URL=http://localhost:3000

# Supabase removed 2026-04-15: AION runs 100% against local PostgreSQL via Fastify backend.
# Auth uses backend-issued JWT (@fastify/jwt + scrypt); realtime uses native WebSocket.

# ── External Integrations (Optional — leave empty if not needed) ──

# ElevenLabs Text-to-Speech
# IMPORTANT: The primary API key is now configured in backend/.env as ELEVENLABS_API_KEY
# This frontend var is only used as a direct fallback if the backend voice API is unreachable.
# Get key at: https://elevenlabs.io/settings/api-keys
VITE_ELEVENLABS_API_KEY=

# WhatsApp Business API (DEPRECATED — credentials now stored in backend DB)
# These frontend vars are kept for backward compatibility only.
# Configure WhatsApp via the UI at /whatsapp > Configuration tab.
VITE_WHATSAPP_PHONE_NUMBER_ID=
VITE_WHATSAPP_ACCESS_TOKEN=
VITE_WHATSAPP_BUSINESS_ID=

# eWeLink / Sonoff Smart Devices
# IMPORTANT: eWeLink credentials (EWELINK_APP_ID, EWELINK_APP_SECRET) belong
# in backend/.env ONLY. Do NOT set any VITE_EWELINK_* variables here.
# Register at: https://dev.ewelink.cc — then configure in backend/.env

# VoIP / SIP Intercom (for browser-based WebRTC calls)
# Primary SIP/PBX config is in backend/.env (SIP_HOST, SIP_ARI_URL, etc.)
# These frontend vars are only needed for direct WebRTC calls from the browser.
# For WebRTC, use WSS transport with TLS-enabled PBX.
VITE_SIP_SERVER=
VITE_SIP_PORT=8089
VITE_SIP_TRANSPORT=wss
VITE_SIP_DOMAIN=
