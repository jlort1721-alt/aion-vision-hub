# /opt/aion/observability/.env
# DO NOT commit. Mode 600, owner aion.

# --- Slack ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/XXXXXXXX

# --- Email (Sendgrid) ---
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# --- Bearer used by Alertmanager → AION comms webhook (WhatsApp on-call) ---
ALERTMANAGER_BEARER=$(openssl rand -hex 32)

# --- QA bot bearer for blackbox-authed probes ---
QA_BOT_BEARER=eyJhbGc...   # JWT issued for qa-bot@aionseg.co

# --- Vision Hub auth (if internal endpoint requires it) ---
VISION_HUB_TOKEN=

# --- Postgres ---
# Read-only role for Grafana datasource and exporters
AION_DB_URL_RO=postgres://aion_grafana_ro:CHANGEME@host.docker.internal:5432/aion?sslmode=disable
PG_GRAFANA_PASS=CHANGEME

# --- Grafana admin ---
GRAFANA_ADMIN_PASS=$(openssl rand -base64 24)

# --- Hint: create the read-only DB role with: ---
#   CREATE ROLE aion_grafana_ro LOGIN PASSWORD '...';
#   GRANT pg_read_all_stats, pg_monitor TO aion_grafana_ro;
#   GRANT CONNECT ON DATABASE aion TO aion_grafana_ro;
#   GRANT USAGE ON SCHEMA public TO aion_grafana_ro;
#   GRANT SELECT ON ALL TABLES IN SCHEMA public TO aion_grafana_ro;
#   ALTER DEFAULT PRIVILEGES IN SCHEMA public
#     GRANT SELECT ON TABLES TO aion_grafana_ro;
