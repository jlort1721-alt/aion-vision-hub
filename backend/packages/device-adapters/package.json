    "undici": "^8.1.0",
    "onvif": "^0.8.1",
    "fast-xml-parser": "^5.5.12",
    "node-digest-auth-client": "^1.0.0"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "@types/node": "^25.6.0",
    "vitest": "^4.1.4"
  }
