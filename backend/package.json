{
  "name": "@aion/backend",
  "private": true,
  "version": "1.0.0",
  "description": "AION Vision Hub — Production Backend & Edge Gateway Monorepo",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:api": "turbo run dev --filter=@aion/backend-api",
    "dev:gateway": "turbo run dev --filter=@aion/edge-gateway",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch --parallel",
    "test:coverage": "turbo run test:coverage",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate --filter=@aion/backend-api",
    "db:migrate": "turbo run db:migrate --filter=@aion/backend-api",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  }
}
