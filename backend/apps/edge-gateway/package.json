{
  "name": "@aion/edge-gateway",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --ext .ts"
  },
  "dependencies": {
    "@aion/shared-contracts": "workspace:*",
    "@aion/common-utils": "workspace:*",
    "@aion/device-adapters": "workspace:*",
    "fastify": "^5.2.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/websocket": "^11.0.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6",
    "dotenv": "^17.3.1",
    "undici": "^7.24.4"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "vitest": "^4.1.0",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
