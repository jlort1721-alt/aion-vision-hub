# ═══════════════════════════════════════════════════════════════════
# AION Vision Hub — Backend API Environment Configuration
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the required values.
#
# Legend:
#   [REQUIRED]     Must be set for the server to start
#   [REQUIRED-PROD] Must be set in production; optional in development
#   [OPTIONAL]     Has a sensible default or enables an optional feature
# ═══════════════════════════════════════════════════════════════════


# ─── Server ────────────────────────────────────────────────────────

# [OPTIONAL] Port the HTTP server listens on (default: 3000)
PORT=3000

# [OPTIONAL] Bind address (default: 0.0.0.0)
HOST=0.0.0.0

# [OPTIONAL] Runtime environment (default: development)
# Values: development | production | test
NODE_ENV=development


# ─── Database ──────────────────────────────────────────────────────

# [REQUIRED] PostgreSQL connection string
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
# For local Docker Compose: postgres://aion:aion_dev_password@localhost:5432/aion_vision_hub
DATABASE_URL=postgres://aion:aion_dev_password@localhost:5432/aion_vision_hub


# ─── Redis ─────────────────────────────────────────────────────────

# [OPTIONAL] Redis URL for caching and pub/sub. Falls back to in-memory when unset.
# For local Docker Compose: redis://localhost:6379
# REDIS_URL=redis://localhost:6379


# ─── Authentication (JWT) ─────────────────────────────────────────

# [REQUIRED] Secret key for signing JWTs. MUST be at least 32 characters.
# Generate with: openssl rand -hex 32
JWT_SECRET=REPLACE-ME-generate-with-openssl-rand-hex-32

# [OPTIONAL] Issuer claim embedded in JWTs (default: aion-vision-hub)
JWT_ISSUER=aion-vision-hub

# [OPTIONAL] Token expiration duration (default: 24h)
# Examples: 1h, 12h, 24h, 7d
JWT_EXPIRATION=24h


# ─── CORS ──────────────────────────────────────────────────────────

# [OPTIONAL] Comma-separated list of allowed origins (default: http://localhost:5173)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000


# ─── Rate Limiting ─────────────────────────────────────────────────

# [OPTIONAL] Max requests per window per IP (default: 100)
# RATE_LIMIT_MAX=100

# [OPTIONAL] Time window in milliseconds (default: 60000 = 1 minute)
# RATE_LIMIT_WINDOW_MS=60000


# ─── Credential Encryption ─────────────────────────────────────────

# [REQUIRED-PROD] AES key for encrypting device credentials at rest.
# Must be at least 32 characters. REQUIRED in production, optional in dev.
# Generate with: openssl rand -hex 16
# CREDENTIAL_ENCRYPTION_KEY=


# ─── AI Providers ──────────────────────────────────────────────────

# [OPTIONAL] OpenAI API key for GPT models
# Get one at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# [OPTIONAL] Anthropic API key for Claude models
# Get one at: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...


# ─── ElevenLabs Text-to-Speech ─────────────────────────────────────

# [OPTIONAL] Enables AI voice synthesis for intercom
# Get API key at: https://elevenlabs.io/settings/api-keys
# ELEVENLABS_API_KEY=sk_...

# [OPTIONAL] Default voice ID (default: none — must pick one from ElevenLabs dashboard)
# ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# [OPTIONAL] TTS model (default: eleven_multilingual_v2)
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2


# ─── Email Provider (pick ONE) ─────────────────────────────────────
# Configure exactly one provider. If multiple are set, priority is:
# Resend > SendGrid > SMTP

# Option A: Resend (recommended — https://resend.com)
# RESEND_API_KEY=re_xxxxxxxxxxxx

# Option B: SendGrid (https://sendgrid.com)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx

# Option C: SMTP (self-hosted)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=your-smtp-password

# Sender identity (used by all providers)
# EMAIL_FROM_ADDRESS=noreply@yourdomain.com
# EMAIL_FROM_NAME=AION Vision Hub


# ─── WhatsApp Business API (Cloud API) ─────────────────────────────
# Credentials can also be managed per-tenant via the UI.
# Env vars here serve as defaults for new tenants.

# [OPTIONAL] Meta WhatsApp phone number ID
# WHATSAPP_PHONE_NUMBER_ID=

# [OPTIONAL] Meta permanent access token
# WHATSAPP_ACCESS_TOKEN=

# [OPTIONAL] Meta business account ID
# WHATSAPP_BUSINESS_ACCOUNT_ID=

# [OPTIONAL] Webhook verification token (you define this; must match Meta config)
# WHATSAPP_VERIFY_TOKEN=your-random-verify-token

# [OPTIONAL] Meta app secret for webhook signature verification (min 32 chars)
# WHATSAPP_APP_SECRET=

# [OPTIONAL] Graph API version (default: v21.0)
# WHATSAPP_API_VERSION=v21.0


# ─── VoIP / SIP / Intercom ────────────────────────────────────────

# [OPTIONAL] SIP/PBX server address (e.g., Asterisk, FreePBX)
# SIP_HOST=192.168.1.100

# [OPTIONAL] SIP port (default: 5060)
# SIP_PORT=5060

# [OPTIONAL] SIP transport protocol (default: udp)
# Values: udp | tcp | tls | wss
# SIP_TRANSPORT=udp

# [OPTIONAL] SIP domain for registration
# SIP_DOMAIN=pbx.mysite.com

# [OPTIONAL] Asterisk ARI (REST Interface) for call control
# SIP_ARI_URL=http://192.168.1.100:8088/ari
# SIP_ARI_USERNAME=aion
# SIP_ARI_PASSWORD=your-ari-password

# [OPTIONAL] Fanvil intercom device credentials (required when using Fanvil intercoms)
# FANVIL_ADMIN_USER=admin
# FANVIL_ADMIN_PASSWORD=your-fanvil-password


# ─── eWeLink / Sonoff Smart Devices ───────────────────────────────
# Backend proxy for eWeLink API. Credentials MUST NOT be in the frontend.
# Register at: https://dev.ewelink.cc

# [OPTIONAL] eWeLink developer app ID
# EWELINK_APP_ID=your-ewelink-app-id

# [OPTIONAL] eWeLink developer app secret
# EWELINK_APP_SECRET=your-ewelink-app-secret

# [OPTIONAL] eWeLink region (default: us)
# Values: us | eu | as | cn
# EWELINK_REGION=us


# ─── Push Notifications (VAPID / Web Push) ────────────────────────

# [OPTIONAL] VAPID keys for Web Push notifications (PWA)
# Generate with: npx tsx scripts/generate-vapid-keys.ts
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# [OPTIONAL] VAPID subject - contact email for push service providers
# VAPID_SUBJECT=mailto:admin@aionvisionhub.com


# ─── Logging ───────────────────────────────────────────────────────

# [OPTIONAL] Log level (default: info)
# Values: fatal | error | warn | info | debug | trace
LOG_LEVEL=info


# ─── Monitoring / Observability ──────────────────────────────────

# [OPTIONAL] OpenTelemetry OTLP endpoint for trace export.
# Leave unset to use the default (http://localhost:4318/v1/traces).
# Set to your Grafana Tempo, Jaeger, or OTEL Collector endpoint.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318/v1/traces

# [OPTIONAL] Enable Prometheus metrics endpoint (default: true)
# PROMETHEUS_ENABLED=true

# [OPTIONAL] Grafana admin password (default: admin)
# Only used with docker-compose.monitoring.yml
# GRAFANA_ADMIN_PASSWORD=change-me-in-production
