# ═══════════════════════════════════════════════════════════
# AION VISION HUB — Production Environment Variables
# Copy this to .env.docker on your production VPS
# ═══════════════════════════════════════════════════════════

# ── Domain & SSL ──────────────────────────────────────────
DOMAIN=app.yourdomain.com
ACME_EMAIL=admin@yourdomain.com
# If using Cloudflare DNS challenge:
# CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# ── Database ──────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME_USE_openssl_rand_base64_32
# Or use Supabase connection string:
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── Redis ─────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_USE_openssl_rand_base64_32

# ── Authentication ────────────────────────────────────────
JWT_SECRET=CHANGE_ME_USE_openssl_rand_base64_48_min_32_chars
JWT_ISSUER=aion-vision-hub
JWT_EXPIRATION=24h

# ── Supabase (for Auth) ──────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=https://app.yourdomain.com,https://yourdomain.com

# ── Security ──────────────────────────────────────────────
CREDENTIAL_ENCRYPTION_KEY=CHANGE_ME_USE_openssl_rand_base64_48_min_32_chars
RATE_LIMIT_MAX=200
LOG_LEVEL=info

# ── Gateway ───────────────────────────────────────────────
GATEWAY_ID=gw-prod-01
DISCOVERY_NETWORK_RANGE=192.168.1.0/24

# ── AI Providers (optional) ───────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Voice (optional) ─────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ── Email (pick one provider) ────────────────────────────
RESEND_API_KEY=
# SENDGRID_API_KEY=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
EMAIL_FROM_NAME=AION Vision Hub

# ── WhatsApp Business Cloud API ──────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=CHANGE_ME_random_string
WHATSAPP_APP_SECRET=CHANGE_ME_min_32_chars

# ── eWeLink / Sonoff (optional) ──────────────────────────
EWELINK_APP_ID=
EWELINK_APP_SECRET=
EWELINK_REGION=us

# ── SIP / VoIP (optional) ────────────────────────────────
SIP_HOST=
SIP_PORT=5060
SIP_TRANSPORT=udp
SIP_ARI_URL=
SIP_ARI_USERNAME=
SIP_ARI_PASSWORD=
