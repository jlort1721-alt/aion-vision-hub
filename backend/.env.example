# ═══════════════════════════════════════════════════════════
# AION Vision Hub — Backend Environment Configuration
# ═══════════════════════════════════════════════════════════
# Copy to .env and fill in required values

# ── General ──────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgres://aion:aion_dev_password@localhost:5432/aion_vision_hub
POSTGRES_PASSWORD=aion_dev_password

# ── JWT (REQUIRED - must match across all services) ──────
JWT_SECRET=your-jwt-secret-minimum-32-characters-long-replace-this
JWT_ISSUER=aion-vision-hub

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Backend API ──────────────────────────────────────────
# PORT=3000
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW_MS=60000

# ── Edge Gateway ─────────────────────────────────────────
GATEWAY_ID=gw-local-01
# SITE_ID=
BACKEND_API_URL=http://localhost:3000
# BACKEND_API_KEY=

# ── MediaMTX ─────────────────────────────────────────────
MEDIAMTX_API_URL=http://localhost:9997
# MEDIAMTX_RTSP_PORT=8554

# ── Device Defaults ──────────────────────────────────────
# DEVICE_CONNECT_TIMEOUT_MS=5000
# DEVICE_PING_INTERVAL_MS=30000
# DEVICE_RECONNECT_MAX_ATTEMPTS=5
# DEVICE_RECONNECT_BASE_DELAY_MS=2000

# ── Discovery ────────────────────────────────────────────
DISCOVERY_NETWORK_RANGE=192.168.1.0/24
# DISCOVERY_TIMEOUT_MS=10000

# ── AI Providers (optional) ──────────────────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── ElevenLabs TTS (optional — enables AI voice for intercom) ──
# Get API key at: https://elevenlabs.io/settings/api-keys
# ELEVENLABS_API_KEY=sk_...
# ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ── VoIP / SIP / Intercom ──────────────────────────────────
# SIP server (Asterisk/FreePBX) — required for real intercom calls
# SIP_HOST=192.168.1.100
# SIP_PORT=5060
# SIP_TRANSPORT=udp
# SIP_DOMAIN=pbx.mysite.com

# Asterisk ARI (REST API for call control) — required for call origination
# SIP_ARI_URL=http://192.168.1.100:8088/ari
# SIP_ARI_USERNAME=aion
# SIP_ARI_PASSWORD=your-ari-password

# Fanvil device credentials (REQUIRED when intercom module is used — NO DEFAULTS)
# FANVIL_ADMIN_USER=your-fanvil-admin-user
# FANVIL_ADMIN_PASSWORD=your-fanvil-admin-password

# ── Credential Encryption (REQUIRED in production) ───────
# Generate: openssl rand -hex 16
# CREDENTIAL_ENCRYPTION_KEY=your-32-char-encryption-key-here

# ── Email Provider (pick ONE: Resend, SendGrid, or SMTP) ──
# Resend (recommended — https://resend.com)
# RESEND_API_KEY=re_xxxxxxxxxxxx

# SendGrid (alternative — https://sendgrid.com)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx

# SMTP (self-hosted fallback — requires nodemailer)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=your-smtp-password

# Sender identity (used by all providers)
# EMAIL_FROM_ADDRESS=noreply@yourdomain.com
# EMAIL_FROM_NAME=AION Vision Hub

# ── WhatsApp Business API (Cloud API) ────────────────────
# Credentials can also be configured via the UI at /whatsapp > Configuration.
# If set here, they serve as defaults for new tenants.
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_BUSINESS_ACCOUNT_ID=
# WHATSAPP_VERIFY_TOKEN=your-random-verify-token
# WHATSAPP_APP_SECRET=your-meta-app-secret-for-webhook-signature-verification
# WHATSAPP_API_VERSION=v21.0

# ── eWeLink / Sonoff (backend proxy — credentials MUST NOT be in frontend) ──
# Register at: https://dev.ewelink.cc
# EWELINK_APP_ID=your-ewelink-app-id
# EWELINK_APP_SECRET=your-ewelink-app-secret
# EWELINK_REGION=us

# ── Cache ────────────────────────────────────────────────
# CACHE_MAX_ENTRIES=500
# CACHE_TTL_MS=300000

# ── Heartbeat ────────────────────────────────────────────
# HEARTBEAT_INTERVAL_MS=60000
