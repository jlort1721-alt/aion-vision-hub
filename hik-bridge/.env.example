# ═══════════════════════════════════════════════════════════
# AION Hikvision Bridge (HCNetSDK) — Environment Variables
# ═══════════════════════════════════════════════════════════

# Server
HIK_BRIDGE_HOST=0.0.0.0
HIK_BRIDGE_PORT=8100

# Authentication (shared secret with AION Fastify backend)
HIK_BRIDGE_API_KEY=change-me-to-a-secure-random-string

# AION Backend API (for fetching device credentials)
AION_API_URL=http://localhost:3001
AION_API_KEY=change-me-to-aion-api-key

# Redis (same instance as AION)
REDIS_URL=redis://localhost:6379/3

# HCNetSDK native libraries
HIK_SDK_LIB_PATH=/opt/aion/hik-bridge/venv/lib/python3.11/site-packages/hikvision_sdk/lib
HIK_SDK_LOG_DIR=/var/log/aion/hik-bridge/sdk
HIK_SDK_LOG_LEVEL=3

# Storage directories
HIK_SNAPSHOTS_DIR=/opt/aion/hik-bridge/snapshots
HIK_DOWNLOADS_DIR=/opt/aion/hik-bridge/downloads

# Connection pool
HIK_MAX_CONNECTIONS=50
HIK_HEARTBEAT_INTERVAL=30
HIK_RECONNECT_MAX_DELAY=300
HIK_LOGIN_TIMEOUT=10
HIK_SEARCH_TIMEOUT=30
HIK_DOWNLOAD_TIMEOUT=300

# Logging
LOG_LEVEL=info
