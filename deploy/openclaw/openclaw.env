# ═══════════════════════════════════════════════════════════
# OpenClaw Environment — AION VPS (v2)
# Archivo: /home/openclaw/.openclaw/.env
# Permisos: chmod 600 (solo usuario openclaw)
# ═══════════════════════════════════════════════════════════

# Gateway token — generar con: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=3897843589c923399454e191b5364dd994cceeead74f870eef5ac8070db5870e

# ── Proveedor AI (elegir UNO al inicio) ──────────────────
# Anthropic (recomendado para AION)
ANTHROPIC_API_KEY=REEMPLAZA_TU_ANTHROPIC_KEY

# OpenAI (alternativa)
# OPENAI_API_KEY=REEMPLAZA_TU_OPENAI_KEY

# Google (alternativa)
# GOOGLE_API_KEY=REEMPLAZA_TU_GOOGLE_KEY

# ── Aislamiento de runtime ───────────────────────────────
OPENCLAW_HOME=/home/openclaw/.openclaw
OPENCLAW_STATE_DIR=/home/openclaw/.openclaw/state
OPENCLAW_CONFIG_PATH=/home/openclaw/.openclaw/openclaw.json

# ── AION REST API (aion-api-query wrapper) ───────────────
# Crear con: POST /api-keys en AION, o usar setup-aion-apikey.sh
# Permisos: solo lectura (devices, events, cameras, sites, alerts)
AION_API_KEY=pending-setup

# ── DB read-only (aion-db-reader agent) ──────────────────
# Crear con: sudo -u postgres psql -f setup-db-readonly.sql
AION_DB_READONLY_URL=postgresql://openclaw_reader:OC_r3ad0nly_2026!@127.0.0.1:5432/aionseg_prod

# ── GitHub (aion-devops agent) ───────────────────────────
# Personal access token con permisos: repo (read/write)
# Crear en: https://github.com/settings/tokens
GITHUB_TOKEN=pending-setup
GITHUB_REPO=jlort1721-alt/aion-platform

# ── Continuous Improvement ───────────────────────────────
# Intervalo en segundos (default 1800 = 30 min)
IMPROVEMENT_INTERVAL=1800
