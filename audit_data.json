  "findings": [
    {
      "severity": "CRITICAL",
      "id": "F01",
      "title": "Go reverse-gateway never deployed",
      "description": "The Go binary at reverse-gateway/ was never compiled, deployed, or run on the VPS. The reverse PostgreSQL schema does not exist. All architecture designed around reverse.devices/sessions/streams/routes is inactive.",
      "impact": "No ISUP SDK sessions, no Dahua SDK sessions, no reverse-channel streaming, no encrypted credential storage, no session management."
    },
    {
      "severity": "CRITICAL",
      "id": "F02",
      "title": "Platform server is a Python stub",
      "description": "device-platform-server.py accepts TCP connections on 7660/7681 but only logs IP+port. It does NOT authenticate, maintain sessions, or enable streaming. Registered data stored in a flat JSON file with no serial numbers.",
      "impact": "Device 'registrations' are cosmetic — no actual ISUP/DHIP functionality."
    },
    {
      "severity": "CRITICAL",
