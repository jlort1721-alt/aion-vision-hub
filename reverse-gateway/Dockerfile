# syntax=docker/dockerfile:1.7
#
# AION Reverse-Connect Gateway - production image.
#
# Stage 1: build with cgo against the vendor SDKs mounted at build time.
# Stage 2: runtime with only the .so files + the gateway binary + ffmpeg.
#
# Build:
#   docker build \
#     --build-arg BUILD_SDKS=1 \
#     --secret id=dahua_sdk,src=./sdks/dahua.tar.gz \
#     --secret id=hik_sdk,src=./sdks/hikvision.tar.gz \
#     -t aion/reverse-gateway:v1.1.0 .
#
# Run:
#   docker run -d \
#     --name aion-reverse-gateway \
#     --network host \
#     -v /etc/aion/reverse:/etc/aion/reverse:ro \
#     -v /var/log/aion:/var/log/aion \
#     aion/reverse-gateway:v1.1.0

ARG GO_VERSION=1.22
ARG DEBIAN_VERSION=bookworm

# ---------------------------------------------------------------- builder
FROM golang:${GO_VERSION}-${DEBIAN_VERSION} AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
      build-essential \
      pkg-config \
      ca-certificates \
      git \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /src

# Copy SDKs (mounted as secrets to keep proprietary bits out of layers)
# Expected archive layout inside each tarball:
#   lib/*.so
#   include/*.h
ARG BUILD_SDKS=0
RUN --mount=type=secret,id=dahua_sdk,target=/tmp/dahua.tar.gz,required=false \
    --mount=type=secret,id=hik_sdk,target=/tmp/hikvision.tar.gz,required=false \
    mkdir -p /src/sdks/dahua /src/sdks/hikvision && \
    if [ "$BUILD_SDKS" = "1" ] && [ -s /tmp/dahua.tar.gz ]; then \
      tar -xzf /tmp/dahua.tar.gz -C /src/sdks/dahua --strip-components=1; \
    fi && \
    if [ "$BUILD_SDKS" = "1" ] && [ -s /tmp/hikvision.tar.gz ]; then \
      tar -xzf /tmp/hikvision.tar.gz -C /src/sdks/hikvision --strip-components=1; \
    fi

COPY go.mod ./
# go.sum is generated by `go mod download` in CI; dev builds tolerate missing.
RUN --mount=type=cache,target=/go/pkg/mod \
    go mod download || true

COPY . .

# Build tags gate cgo paths; if SDKs are not mounted, stub build still works.
ARG BUILD_TAGS=""
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    set -eu; \
    TAGS=""; \
    if [ -f /src/sdks/dahua/lib/libdhnetsdk.so ];    then TAGS="$TAGS sdk_dahua";    fi; \
    if [ -f /src/sdks/hikvision/lib/libhcnetsdk.so ]; then TAGS="$TAGS sdk_hikvision"; fi; \
    echo "Building with tags: ${TAGS:-<stub>}"; \
    CGO_ENABLED=1 \
    go build \
      -trimpath \
      -tags "$TAGS" \
      -ldflags "-s -w -X main.version=${GIT_SHA:-dev}" \
      -o /out/gateway \
      ./cmd/gateway

# ---------------------------------------------------------------- runtime
FROM debian:${DEBIAN_VERSION}-slim AS runtime

RUN apt-get update && apt-get install -y --no-install-recommends \
      ca-certificates \
      ffmpeg \
      tini \
      libssl3 \
      libstdc++6 \
      tzdata \
      curl \
  && rm -rf /var/lib/apt/lists/* \
  && useradd --system --uid 10051 --home /var/lib/aion --shell /usr/sbin/nologin aion-reverse

# SDK libraries for runtime linking
COPY --from=builder /src/sdks/dahua/lib       /opt/aion/sdks/dahua/lib
COPY --from=builder /src/sdks/hikvision/lib   /opt/aion/sdks/hikvision/lib

ENV LD_LIBRARY_PATH=/opt/aion/sdks/dahua/lib:/opt/aion/sdks/hikvision/lib
ENV TZ=America/Bogota

COPY --from=builder /out/gateway /usr/local/bin/aion-reverse-gateway

USER aion-reverse
EXPOSE 7660 7661 7681 9464 50551 51551

HEALTHCHECK --interval=30s --timeout=3s --retries=3 \
  CMD curl -fsS http://127.0.0.1:9464/health || exit 1

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["/usr/local/bin/aion-reverse-gateway", "--config", "/etc/aion/reverse/gateway.toml"]
