# ═══════════════════════════════════════════════════════════
# AION Vision Hub — Gateway Environment Variables
# Copy to .env and fill in actual values
# ═══════════════════════════════════════════════════════════

# Server
PORT=3100
NODE_ENV=development
LOG_LEVEL=info

# Supabase (for syncing device state back to cloud DB)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key...

# JWT Secret (must match Supabase JWT secret for token verification)
JWT_SECRET=your-supabase-jwt-secret-at-least-32-chars

# CORS (frontend origins, comma-separated)
CORS_ORIGINS=http://localhost:5173,https://your-app.lovable.app

# MediaMTX (RTSP → WebRTC proxy)
MEDIAMTX_API_URL=http://localhost:9997

# Device defaults
DEVICE_CONNECT_TIMEOUT_MS=5000
DEVICE_PING_INTERVAL_MS=30000

# Discovery
DISCOVERY_TIMEOUT_MS=10000
DISCOVERY_NETWORK_RANGE=192.168.1.0/24
