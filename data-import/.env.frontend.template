# ═══════════════════════════════════════════════════════════════════════════════
# CLAVE SEGURIDAD — Variables Frontend (Vite)
# ═══════════════════════════════════════════════════════════════════════════════
# Copiar a la raíz del proyecto como .env.local
# cp data-import/.env.frontend.template .env.local
# ═══════════════════════════════════════════════════════════════════════════════

# ── Backend API ──────────────────────────────────────────
# URL del backend Fastify (sin / al final)
VITE_API_URL=http://localhost:3000

# ── Supabase (Autenticación) ────────────────────────────
# Obtener de: https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=<<REEMPLAZAR_URL_SUPABASE>>
VITE_SUPABASE_PUBLISHABLE_KEY=<<REEMPLAZAR_ANON_KEY>>

# ── WebRTC / Streaming (MediaMTX) ───────────────────────
# Puerto WebRTC de MediaMTX (default 8889)
VITE_WEBRTC_URL=http://localhost:8889

# ── VoIP / SIP (Citofonía en navegador) ─────────────────
# Solo necesario si se usa citofonía desde el navegador web
# VITE_SIP_SERVER=<<IP_DEL_PBX>>
# VITE_SIP_PORT=8089
# VITE_SIP_TRANSPORT=wss
# VITE_SIP_DOMAIN=<<DOMINIO_SIP>>
