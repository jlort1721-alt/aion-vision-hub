# ═══════════════════════════════════════════════════════════════════════════════
# CLAVE SEGURIDAD — CONFIGURACIÓN COMPLETA PARA PLATAFORMA 100% OPERATIVA
# ═══════════════════════════════════════════════════════════════════════════════
#
# Este archivo contiene TODAS las variables necesarias para que cada módulo
# funcione completamente. Sigue las instrucciones en cada sección.
#
# INSTRUCCIONES:
# 1. Copiar a backend/.env → cp data-import/.env.complete.template backend/.env
# 2. Reemplazar TODOS los <<REEMPLAZAR>> con valores reales
# 3. Generar secretos con los comandos indicados
# 4. NUNCA subir este archivo a Git con datos reales
#
# MÓDULOS QUE DEPENDEN DE CADA SECCIÓN:
# [CORE]       → Todos los módulos
# [EMAIL]      → Alertas, Reportes, Notificaciones, Incidentes
# [WHATSAPP]   → WhatsApp, Alertas, Notificaciones
# [AI]         → Asistente IA, Analíticas, Eventos (resúmenes)
# [VOIP]       → Citofonía IP, Panel Telefónico
# [EWELINK]    → Domóticos
# [PUSH]       → Alertas Push, Notificaciones móvil
# [STREAMING]  → Vista en Vivo, Reproducción
# [MONITORING] → Salud del Sistema
#
# ═══════════════════════════════════════════════════════════════════════════════

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ [CORE] OBLIGATORIO — Sin esto NADA funciona                                │
# └─────────────────────────────────────────────────────────────────────────────┘

NODE_ENV=production
LOG_LEVEL=info
PORT=3000
HOST=0.0.0.0

# Base de datos PostgreSQL 16
# Generar password: openssl rand -base64 24
DATABASE_URL=postgres://aion:<<REEMPLAZAR_PASSWORD_DB>>@localhost:5432/aion_vision_hub
POSTGRES_PASSWORD=<<REEMPLAZAR_PASSWORD_DB>>

# JWT — Autenticación de usuarios
# Generar: openssl rand -base64 48
JWT_SECRET=<<REEMPLAZAR_JWT_SECRET_64_CHARS>>
JWT_ISSUER=clave-seguridad
JWT_EXPIRATION=24h

# CORS — URLs del frontend (separar con coma, SIN espacios)
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Cifrado de credenciales de dispositivos (AES-256-GCM)
# Generar: openssl rand -hex 16
CREDENTIAL_ENCRYPTION_KEY=<<REEMPLAZAR_32_CHARS_HEX>>

# Redis (RECOMENDADO para producción — mejora cache y rate limiting)
REDIS_URL=redis://localhost:6379

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ [STREAMING] Vista en Vivo + Reproducción                                    │
# │ Módulos: Vista en Vivo, Reproducción, Dispositivos                          │
# │ Requiere: MediaMTX corriendo                                                │
# └─────────────────────────────────────────────────────────────────────────────┘

# MediaMTX — Convierte RTSP a WebRTC para vista en vivo
MEDIAMTX_API_URL=http://localhost:9997
# MEDIAMTX_RTSP_PORT=8554

# Rango de red para descubrimiento automático de cámaras
DISCOVERY_NETWORK_RANGE=192.168.1.0/24

# Timeouts de conexión a dispositivos
# DEVICE_CONNECT_TIMEOUT_MS=5000
# DEVICE_PING_INTERVAL_MS=30000
# DEVICE_RECONNECT_MAX_ATTEMPTS=5
# DEVICE_RECONNECT_BASE_DELAY_MS=2000

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ [EMAIL] Correo Electrónico — Notificaciones y Alertas                       │
# │ Módulos: Alertas, Reportes, Reportes Programados, Incidentes, Emergencias   │
# │ Elegir UNO de los 3 proveedores:                                            │
# └─────────────────────────────────────────────────────────────────────────────┘

# ── Opción 1: SMTP (Gmail, Outlook, propio) ──────────────
# Para Gmail: crear App Password en https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<<REEMPLAZAR>>@claveseguridad.com
SMTP_PASS=<<REEMPLAZAR_APP_PASSWORD>>

# ── Opción 2: Resend (recomendado) ───────────────────────
# Crear cuenta en https://resend.com y obtener API key
# RESEND_API_KEY=re_<<REEMPLAZAR>>

# ── Opción 3: SendGrid ───────────────────────────────────
# SENDGRID_API_KEY=SG.<<REEMPLAZAR>>

# Remitente (usado por todos los proveedores)
EMAIL_FROM_ADDRESS=notificaciones@claveseguridad.com
EMAIL_FROM_NAME=Clave Seguridad

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ [WHATSAPP] WhatsApp Business API (Meta)                                     │
# │ Módulos: WhatsApp, Alertas, Notificaciones, Emergencias                     │
# │ Configurar en: https://developers.facebook.com → WhatsApp Business          │
# └─────────────────────────────────────────────────────────────────────────────┘

# Paso 1: Crear app en Meta for Developers
# Paso 2: Agregar producto "WhatsApp Business"
# Paso 3: Configurar número de teléfono
# Paso 4: Obtener token de acceso permanente

WHATSAPP_PHONE_NUMBER_ID=<<REEMPLAZAR_ID_NUMERO>>
WHATSAPP_ACCESS_TOKEN=<<REEMPLAZAR_TOKEN_PERMANENTE>>
WHATSAPP_BUSINESS_ACCOUNT_ID=<<REEMPLAZAR_ID_CUENTA>>
WHATSAPP_VERIFY_TOKEN=<<REEMPLAZAR_TOKEN_VERIFICACION_WEBHOOK>>
WHATSAPP_APP_SECRET=<<REEMPLAZAR_SECRETO_APP_MINIMO_32_CHARS>>
WHATSAPP_API_VERSION=v21.0

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ [AI] Proveedores de Inteligencia Artificial                                 │
# │ Módulos: Asistente IA, Analíticas, Eventos (resúmenes automáticos)          │
# │ Configurar al menos UNO para habilitar IA                                   │
# └─────────────────────────────────────────────────────────────────────────────┘

# ── OpenAI ────────────────────────────────────────────────
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-<<REEMPLAZAR>>

# ── Anthropic Claude ──────────────────────────────────────
# Obtener en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-<<REEMPLAZAR>>

# ── vLLM Local (para ambientes sin internet) ─────────────
# VLLM_API_URL=http://localhost:8000/v1/chat/completions
# VLLM_API_KEY=sk-local-airgapped
# VLLM_MODEL=meta-llama/Meta-Llama-3-8B-Instruct

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ [VOIP] Citofonía IP / SIP / Intercomunicadores                             │
# │ Módulos: Citofonía IP, Panel Telefónico                                     │
# │ Requiere: PBX (Asterisk/FreePBX/3CX) configurado                          │
# └─────────────────────────────────────────────────────────────────────────────┘

# Servidor SIP (PBX)
SIP_HOST=<<REEMPLAZAR_IP_DEL_PBX>>
SIP_PORT=5060
SIP_TRANSPORT=udp
SIP_DOMAIN=<<REEMPLAZAR_DOMINIO_SIP>>

# Asterisk ARI (API REST para control de llamadas)
SIP_ARI_URL=http://<<REEMPLAZAR_IP_PBX>>:8088/ari
SIP_ARI_USERNAME=<<REEMPLAZAR_USUARIO_ARI>>
SIP_ARI_PASSWORD=<<REEMPLAZAR_PASSWORD_ARI>>

# Fanvil (intercomunicadores de puerta/portería)
FANVIL_ADMIN_USER=<<REEMPLAZAR_USUARIO_ADMIN_FANVIL>>
FANVIL_ADMIN_PASSWORD=<<REEMPLAZAR_PASSWORD_ADMIN_FANVIL>>

# ── ElevenLabs TTS (voz para intercomunicadores y alertas) ──
# Obtener en: https://elevenlabs.io/settings/api-keys
ELEVENLABS_API_KEY=sk_<<REEMPLAZAR>>
ELEVENLABS_DEFAULT_VOICE_ID=<<REEMPLAZAR_ID_VOZ>>
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ [EWELINK] Dispositivos Domóticos (Sonoff/eWeLink)                          │
# │ Módulos: Domóticos                                                          │
# │ Registrar app en: https://dev.ewelink.cc                                    │
# └─────────────────────────────────────────────────────────────────────────────┘

EWELINK_APP_ID=<<REEMPLAZAR_APP_ID>>
EWELINK_APP_SECRET=<<REEMPLAZAR_APP_SECRET>>
EWELINK_REGION=us

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ [PUSH] Notificaciones Push (PWA / Navegador)                                │
# │ Módulos: Alertas, Notificaciones, Emergencias                               │
# │ Generar con: cd backend/apps/backend-api && npx tsx scripts/generate-vapid-keys.ts │
# └─────────────────────────────────────────────────────────────────────────────┘

VAPID_PUBLIC_KEY=<<REEMPLAZAR_CLAVE_PUBLICA>>
VAPID_PRIVATE_KEY=<<REEMPLAZAR_CLAVE_PRIVADA>>
VAPID_SUBJECT=mailto:admin@claveseguridad.com

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ [MONITORING] Monitoreo y Observabilidad                                     │
# │ Módulos: Salud del Sistema, Centro de Red                                   │
# └─────────────────────────────────────────────────────────────────────────────┘

PROMETHEUS_ENABLED=true
GRAFANA_ADMIN_PASSWORD=<<REEMPLAZAR_PASSWORD_GRAFANA>>
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ [GATEWAY] Edge Gateway — Comunicación con dispositivos locales              │
# │ Módulos: Dispositivos, Vista en Vivo, Reinicios, Centro de Red              │
# └─────────────────────────────────────────────────────────────────────────────┘

GATEWAY_ID=gw-prod-01
BACKEND_API_URL=http://localhost:3000
# BACKEND_API_KEY=<<REEMPLAZAR_SI_SE_USA_API_KEY>>
